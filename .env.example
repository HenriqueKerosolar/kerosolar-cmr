# ── Banco (Supabase — NOVO projeto separado do KeroService) ───────────────────
DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_DIRECT_URL="postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:5432/postgres"

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# ── Sessão (gere com: openssl rand -base64 32) ────────────────────────────────
SESSION_SECRET=""

# ── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ── Conversions API — Clique-para-WhatsApp (CTWA) ──────────────────────────────
META_DATASET_ID="581688719431430"  # ID do conjunto de dados do Gerenciador de Eventos
META_GRAPH_VERSION="v21.0"          # versão da Graph API usada no envio de eventos
META_CAPI_TOKEN=""                  # token do dataset; se vazio, usa WHATSAPP_CLOUD_TOKEN
